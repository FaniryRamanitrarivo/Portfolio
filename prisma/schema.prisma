generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/**
 * Modèle Project - Portfolio projects
 * Stocke les détails de chaque projet dans le portfolio
 */
model Project {
  id               Int      @id @default(autoincrement())
  title            String   @db.Text
  role             String   @db.Text
  client           String?  @db.Text
  duration         String   @db.Text
  overview         String   @db.Text
  category         String?  @db.Text
  description      String?  @db.Text
  image            String?  @db.Text
  github           String?  @db.Text
  link             String?  @db.Text

  // JSON fields for storing arrays
  responsibilities Json     @default("[]")
  keyResults       Json     @default("[]")
  challenges       Json     @default("[]")
  solutions        Json     @default("[]")
  technologies     Json     @default("[]")

  // Metadata
  popular          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([popular])
  @@index([createdAt])
}